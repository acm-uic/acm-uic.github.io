{
  "name": "acm-uic-github-io",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "prettier:ci": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "prettier:diff": "prettier --list-different \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "lint": "npm run lint:js && npm run lint:md && npm run lint:style",
    "lint:ci": "npm run lint:js -- --quiet && npm run lint:md -- --quiet && npm run lint:style",
    "lint:js": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:md": "eslint \"**/*.{md,mdx}\"",
    "lint:style": "stylelint \"**/*.css\""
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "3.1.1",
    "@svgr/webpack": "8.1.0",
    "clsx": "2.1.1",
    "docusaurus-theme-search-typesense": "0.26.0",
    "dotenv": "17.4.0",
    "file-loader": "6.2.0",
    "linkify-react": "4.3.2",
    "linkifyjs": "4.3.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "swr": "2.4.1",
    "url-loader": "4.1.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@eslint-react/eslint-plugin": "4.2.3",
    "@eslint/js": "10.0.1",
    "@types/gapi": "0.0.47",
    "@types/gapi.client.calendar-v3": "0.0.4",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-helmet": "6.1.11",
    "@types/react-router-dom": "5.3.3",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "prettier": "3.8.2",
    "stylelint": "17.6.0",
    "stylelint-config-recommended": "18.0.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0"
  }
}
